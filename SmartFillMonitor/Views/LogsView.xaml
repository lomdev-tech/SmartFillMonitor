<UserControl x:Class="SmartFillMonitor.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartFillMonitor.Views"
             xmlns:smartFillMonitor="clr-namespace:SmartFillMonitor"
             xmlns:hc="https://handyorg.github.io/handycontrol"                                                                                 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 引入 HandyControl 的核心资源字典（必须） -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <!-- 引入 HandyControl 的所有控件样式（必须） -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <!-- 选项卡控件：承载日志标签页 -->
    <TabControl Style="{StaticResource AppTabControlStyle}">
        <!-- 单个选项卡项，标题显示“Log” -->
        <TabItem Header="Log" Style="{StaticResource  AppTabItemStyle}">
            <!-- 内容控件：把C#中定义的App.LogView嵌入到这个选项卡中 -->
            <ContentControl Content="{x:Static smartFillMonitor:App.LogView}"/>
        </TabItem>
        <TabItem Header="LogAnalyze" Style="{StaticResource AppTabItemStyle}">
            <Grid Margin="10">  
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource AppBgDark}" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="从：" VerticalAlignment="Center" Foreground="White" Margin="0,0,5,0"/>
                        <hc:DateTimePicker SelectedDateTime="{Binding StartDate}" Width="120" VerticalAlignment="Center"/>

                        <TextBlock Text="到：" VerticalAlignment="Center" Foreground="White" Margin="10,0,5,0"/>
                        <hc:DateTimePicker SelectedDateTime="{Binding EndDate}" Width="120" VerticalAlignment="Center"/>

                        <!--UpdateSourceTrigger=PropertyChanged表示实时同步：用户一选中新的等级，就立刻把值传给 ViewModel 的SelecetedLevel（默认是失去焦点才同步，这里改实时），下面的搜索同理-->
                        <TextBlock Text="等级：" VerticalAlignment="Center" Foreground="White" Margin="20,0,5,0"/>
                        <ComboBox SelectedItem="{Binding SelectedLevel,UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding LogLevels}" Width="100" VerticalAlignment="Center"/>

                        <!--ToolTip表示鼠标悬浮在文本框时显示提示文字，告诉用户这个输入框的用途-->
                        <TextBlock Text="搜索：" VerticalAlignment="Center" Foreground="White" Margin="20,0,5,0"/>
                        <TextBox Text="{Binding SearchText,UpdateSourceTrigger=PropertyChanged}" Width="200" VerticalAlignment="Center" ToolTip="输入消息内容或来源进行搜索">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <Button Content="查询" Command="{Binding SearchCommand}" Width="80" Margin="10,0,0,0" Foreground="White" Background="{StaticResource AppAccentColor}"/>
                        <Button Content="导出CSV" Command="{Binding ExportCommand}" Width="80" Margin="10,0,0,0" Foreground="White" Background="{StaticResource AppBgPanel}"/>
                    </StackPanel>
                </Border>

                <!--DataGrid控件默认背景颜色为白色，AutoGenerateColumns="True"表示自动生成列：根据Logs里每条日志的属性，自动创建列（比如日志时间、等级、内容等）-->
                <!--HeadersVisibility="Column"表示只显示列标题（隐藏行标题），视觉更简洁-->
                <!--GridLinesVisibility="Horizontal"表示只显示水平网格线（行分隔线），垂直网格线隐藏-->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Logs}" AutoGenerateColumns="True" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0"/>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- 绑定IsBusy并通过Boolean2VisibilityConverter控制显示：初始/查询完成时隐藏，查询中显示“正在查询”提示 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Visibility="{Binding IsBusy,Converter={StaticResource Boolean2VisibilityConverter}}">
                        <TextBlock Text="正在查询" Foreground="LimeGreen" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!--StringFormat是 WPF 绑定的文本格式化属性，核心作用是给绑定的值加固定文字 / 调整显示格式-->
                    <!-- StringFormat='共{0}条记录'：{0}代表绑定的TotalConut值，单值绑定固定用{0} -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="{Binding TotalCount,StringFormat='共{0}条记录'}" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,20,0"/>
                        <Button Content="上一页" Command="{Binding PreviousPageCommand}" Width="80" Margin="0,0,10,0" Foreground="White" Background="{StaticResource AppBgPanel}"/>
                        <TextBlock Text="{Binding PageIndex,StringFormat='第{0}页'}" VerticalAlignment="Center" Foreground="White" Margin="0,0,20,0" FontWeight="Bold"/>
                        <Button Content="下一页" Command="{Binding NextPageCommand}" Width="80" Foreground="White" Background="{StaticResource AppBgPanel}"/>                       
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
