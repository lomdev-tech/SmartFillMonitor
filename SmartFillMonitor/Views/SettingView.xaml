<UserControl x:Class="SmartFillMonitor.Views.SettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartFillMonitor.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Margin="20" HorizontalAlignment="Left" Width="800">
        <Border Margin="0,0,0,10" Style="{StaticResource CardStyle}">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="通信参数设置" Foreground="{StaticResource AppDanger}" FontSize="14" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="串口号" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="White"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding PortNames}" SelectedItem="{Binding PortName}"/>

                    <TextBlock Text="波特率" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Margin="0,8,0,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaud}" Margin="0,8,0,0"/>

                    <TextBlock Text="数据位" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Margin="0,8,0,0"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding DataBitsOptions}" SelectedItem="{Binding SelectedDataBits}" Margin="0,8,0,0"/>

                    <TextBlock Text="校验位" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Margin="0,8,0,0"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding ParityOptions}" SelectedItem="{Binding SelectedParity}" Margin="0,8,0,0"/>

                    <TextBlock Text="停止位" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Margin="0,8,0,0"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding StopBitsOptions}" SelectedItem="{Binding SelectedStopBits}" Margin="0,8,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <Button Content="保存设置" Command="{Binding SaveCommand}" Width="120" HorizontalAlignment="Left" Height="40"/> 

        <Border Margin="0,10,0,0" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="系统选项" Foreground="{StaticResource AppTextMuted}" FontSize="14" Margin="0,0,0,10"/>
                <StackPanel>
                    <CheckBox Content="启动时自动连接设备" IsChecked="{Binding AutoConnect}" Foreground="{StaticResource AppTextMuted}" Margin="0,0,0,5"/>
                </StackPanel>

                <StackPanel>
                    <CheckBox Content="启用报警声音提示" IsChecked="{Binding AlarmSound}" Foreground="{StaticResource AppTextMuted}" Margin="0,0,0,5"/>
                </StackPanel>

                <StackPanel>
                    <CheckBox Content="开启日志调试(Debug)" IsChecked="{Binding DebugLogMode}" Foreground="{StaticResource AppTextMuted}" Margin="0,0,0,5"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
